{
  "name": "Rol",
  "type": "object",
  "properties": {
    "nombre": {
      "type": "string",
      "description": "Clave del rol (debe coincidir con el enum de User)"
    },
    "descripcion": {
      "type": "string"
    },
    "permisos": {
      "type": "object",
      "description": "Permisos por m\u00f3dulo. Clave = nombre del m\u00f3dulo, valor = nivel de acceso (none, read, write, admin)."
    }
  },
  "required": [
    "nombre"
  ]
}